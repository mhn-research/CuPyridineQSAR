   "source": [
    "# QSAR Model Analyzer and Predictor\n",
    "\n",
    "Loading trained QSAR models, comparing their performance, and generating predictions\n",
    "\n",
    "## Workflow:\n",
    "1. Load all saved model artifacts from Library folder\n",
    "2. Compare model performance and rank them\n",
    "4. Load input data with SMILES features\n",
    "5. Generate predictions using specified strategy\n",
    "6. Save comprehensive results with uncertainty estimates"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f7851029-181c-4a23-ae05-3fe2ec34995e",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import joblib\n",
    "import os\n",
    "from pathlib import Path\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0bcee86f-33f0-4c69-a7fb-e551905ef81a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Mention model names here. \n",
    "model_names = ['01_LinearRegression']\n",
    "\n",
    "# Initialize storage for model components\n",
    "models = {}\n",
    "scalers = {}\n",
    "feature_infos = {}\n",
    "\n",
    "# Load all model artifacts\n",
    "loaded_models = []\n",
    "\n",
    "for model_name in model_names:\n",
    "    model_path = f\"./Library/{model_name}.pkl\"\n",
    "    models[model_name] = joblib.load(model_path)\n",
    "        \n",
    "    # Load scaler\n",
    "    scaler_path = f\"./Library/{model_name}_scaler.pkl\"\n",
    "    scalers[model_name] = joblib.load(scaler_path)\n",
    "        \n",
    "    # Load feature information\n",
    "    feature_path = f\"./Library/{model_name}_features_info.pkl\"\n",
    "    feature_infos[model_name] = joblib.load(feature_path)\n",
    "        \n",
    "    loaded_models.append(model_name)\n",
    "        print(f\"✓ Loaded {model_name}\")\n",
    "\n",
    "print(f\"\\nSuccessfully loaded {len(loaded_models)} models: {loaded_models}\")"
   ]
  }
